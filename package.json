{
	"name": "express-json-validator-middleware",
	"version": "4.0.0",
	"description": "An Express middleware to validate requests against JSON Schemas",
	"type": "commonjs",
	"main": "./src/index.js",
	"types": "./src/index.d.ts",
	"author": "Simon Plenderleith",
	"license": "MIT",
	"packageManager": "bun@1.3.5",
	"keywords": [
		"express",
		"json",
		"validate",
		"validation",
		"validator"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/simonplend/express-json-validator-middleware.git"
	},
	"bugs": {
		"url": "https://github.com/simonplend/express-json-validator-middleware/issues"
	},
	"homepage": "https://github.com/simonplend/express-json-validator-middleware#readme",
	"exports": {
		".": {
			"types": "./src/index.d.ts",
			"require": "./src/index.js",
			"default": "./src/index.js"
		}
	},
	"scripts": {
		"test": "node --test test/*.test.js",
		"test:coverage": "c8 --reporter=text --reporter=lcov node --test test/*.test.js",
		"test:types": "tsc --noEmit -p tsconfig.json",
		"test:install:npm": "node ./scripts/verify-sample-app.mjs npm",
		"test:install:bun": "node ./scripts/verify-sample-app.mjs bun",
		"verify": "node --test test/*.test.js && c8 --reporter=text --reporter=lcov node --test test/*.test.js && tsc --noEmit -p tsconfig.json && node ./scripts/verify-sample-app.mjs npm && node ./scripts/verify-sample-app.mjs bun"
	},
	"peerDependencies": {
		"express": "^4.21.2 || ^5.2.1"
	},
	"dependencies": {
		"@types/express": "^5.0.6",
		"@types/json-schema": "^7.0.15",
		"ajv": "^8.18.0"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"c8": "^11.0.0",
		"express": "^5.2.1",
		"typescript": "^6.0.2"
	},
	"engines": {
		"node": ">=24.0.0",
		"bun": ">=1.3.5"
	},
	"files": [
		"src/*.js",
		"src/*.d.ts"
	]
}
